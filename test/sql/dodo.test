# ============================================================
# Live view for DuckDB UI integration
# ============================================================

# default: no view created
statement ok
use "test/data/firms.csv", clear

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = '_dodo_data'
----
0

statement ok
clear

# enable live view
statement ok
SET dodo_live_view = true

# use creates the view
statement ok
use "test/data/firms.csv", clear

query I
SELECT COUNT(*) FROM _dodo_data
----
5

# keep updates the view
statement ok
keep if year >= 2018

query I
SELECT COUNT(*) FROM _dodo_data
----
3

# generate updates the view with new column
statement ok
generate double_revenue = revenue * 2

query IIIII
SELECT * FROM _dodo_data ORDER BY id LIMIT 1
----
2	Beta	2000	2018	4000

# clear drops the view
statement ok
clear

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = '_dodo_data'
----
0

# disable live view
statement ok
SET dodo_live_view = false

statement ok
use "test/data/firms.csv", clear

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = '_dodo_data'
----
0

statement ok
clear

# ============================================================
# Materialized use (default) vs lazy
# ============================================================

# default: use materializes into dodo._current
statement ok
use "test/data/firms.csv", clear

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = 'dodo' AND table_name = '_current'
----
1

query I
SELECT COUNT(*) FROM dodo._current
----
5

# transformations still work on top of materialized table
statement ok
keep if year >= 2018

query I
count
----
3

# clear drops the materialized table
statement ok
clear

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = 'dodo' AND table_name = '_current'
----
0

# lazy mode: no table created
statement ok
use "test/data/firms.csv", lazy

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_schema = 'dodo' AND table_name = '_current'
----
0

# data still accessible via CTE
query I
count
----
5

statement ok
clear

# sequential use: second use drops first table
statement ok
use "test/data/firms.csv", clear

statement ok
use "test/data/firms.csv", clear

query I
SELECT COUNT(*) FROM dodo._current
----
5

statement ok
clear

# ============================================================
# Undo / Redo / History
# ============================================================

statement ok
use "test/data/firms.csv", clear

statement ok
keep if year >= 2018

statement ok
generate double_rev = revenue * 2

# history shows 3 steps
query IIT
SELECT step_id, undone, command FROM dodo._history ORDER BY step_id
----
0	false	use "test/data/firms.csv", clear
1	false	keep if year >= 2018
2	false	generate double_rev = revenue * 2

# undo removes double_rev
statement ok
undo

query I
SELECT COUNT(*) AS ncols FROM (DESCRIBE (WITH _s0 AS (SELECT * FROM dodo._current), _s1 AS (SELECT * FROM _s0 WHERE year >= 2018) SELECT * FROM _s1))
----
4

# history shows step 2 as undone
query IIT
SELECT step_id, undone, command FROM dodo._history ORDER BY step_id
----
0	false	use "test/data/firms.csv", clear
1	false	keep if year >= 2018
2	true	generate double_rev = revenue * 2

# redo brings it back
statement ok
redo

query I
SELECT COUNT(*) AS ncols FROM (DESCRIBE (WITH _s0 AS (SELECT * FROM dodo._current), _s1 AS (SELECT * FROM _s0 WHERE year >= 2018), _s2 AS (SELECT *, (revenue * 2) AS double_rev FROM _s1) SELECT * FROM _s2))
----
5

# new command after undo clears redo stack
statement ok
undo

statement ok
generate triple_rev = revenue * 3

statement error
redo
----
Nothing to redo

# undo 2 steps at once
statement ok
undo 2

query I
count
----
5

# cannot undo past data load
statement error
undo
----
Nothing to undo

# history terminal command works in lazy mode too
statement ok
clear

statement ok
use "test/data/firms.csv", lazy

statement ok
keep if year >= 2018

# verify history has 2 entries (can't easily match boolean output in test format)
statement ok
history

statement ok
clear

