# name: test/sql/dodo.test
# description: test dodo extension
# group: [sql]

require dodo

# ============================================================
# M0: Extension loads, standard SQL still works
# ============================================================

query I
SELECT 1
----
1

# ============================================================
# M1: use, list, clear, count
# ============================================================

statement ok
use "test/data/firms.csv", clear

query IIRI
list
----
1	Acme	1000	2017
2	Beta	2000	2018
3	Gamma	1500	2017
4	Delta	3000	2018
5	Epsilon	500	2018

query I
count
----
5

statement ok
clear

# ============================================================
# M2: keep, drop, rename
# ============================================================

statement ok
use "test/data/firms.csv", clear

# keep columns
statement ok
keep id name revenue year

query I
count
----
5

# Now reload and test keep if
statement ok
use "test/data/firms.csv", clear

statement ok
keep if year == 2018

query I
count
----
3

# Reload and test drop columns
statement ok
use "test/data/firms.csv", clear

statement ok
drop name

query IRI
list
----
1	1000	2017
2	2000	2018
3	1500	2017
4	3000	2018
5	500	2018

# Reload and test drop if
statement ok
use "test/data/firms.csv", clear

statement ok
drop if year == 2017

query I
count
----
3

# Test rename
statement ok
use "test/data/firms.csv", clear

statement ok
rename revenue sales

query IIIR
list
----
1	Acme	2017	1000
2	Beta	2018	2000
3	Gamma	2017	1500
4	Delta	2018	3000
5	Epsilon	2018	500

