# --- global macros ---

statement ok
global threshold 2000

statement ok
use "test/data/firms.csv", clear

query I
count if revenue >= $threshold
----
2

# ${name} syntax
statement ok
clear

statement ok
global maxrev 3000

statement ok
use "test/data/firms.csv", clear

query I
count if revenue <= ${maxrev}
----
5

# --- macro drop ---

statement ok
local dropme something

statement ok
macro drop dropme

# expanding dropped macro gives empty string
statement ok
use "test/data/firms.csv", clear

query I
count
----
5

# --- scalar ---

statement ok
clear

statement ok
scalar pi = 3.14159

statement ok
scalar r = 2

statement ok
scalar area = pi * r * r

statement ok
use "test/data/firms.csv", clear

# scalar values expand as locals in expressions
statement ok
generate big = revenue > area

query IIRII
list
----
1	Acme	1000	2017	1
2	Beta	2000	2018	1
3	Gamma	1500	2017	1
4	Delta	3000	2018	1
5	Epsilon	500	2018	1

# scalar list
statement ok
clear

statement ok
scalar drop _all

statement ok
scalar myval = 42

query IT
scalar list
----
myval	42

# --- display ---

query I
display "Hello from dodo"
----
Hello from dodo

# --- tempvar ---

statement ok
use "test/data/firms.csv", clear

statement ok
tempvar tmp

statement ok
generate `tmp' = revenue * 2

# The temp variable exists (we can use it)
query I
count if `tmp' > 3000
----
2

# --- tempname ---

statement ok
clear

statement ok
tempname s1

statement ok
scalar `s1' = 1500

# Can access via the tempname — scalar value expands as a local
statement ok
use "test/data/firms.csv", clear

query I
count if revenue > `s1'
----
2

# --- foreach in ---

statement ok
clear

statement ok
use "test/data/firms.csv", clear

statement ok
foreach v in revenue id {
    generate `v'_sq = `v' * `v'
}

# Check that both _sq columns were created
query IIRIII
list
----
1	Acme	1000	2017	1000000	1
2	Beta	2000	2018	4000000	4
3	Gamma	1500	2017	2250000	9
4	Delta	3000	2018	9000000	16
5	Epsilon	500	2018	250000	25

# --- foreach of local ---

statement ok
clear

statement ok
local mylist revenue id

statement ok
use "test/data/firms.csv", clear

statement ok
foreach v of local mylist {
    generate `v'_double = `v' * 2
}

query I
count
----
5

