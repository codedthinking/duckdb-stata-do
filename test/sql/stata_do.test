statement ok
clear

# ============================================================
# M7: save, append, mvencode
# ============================================================

# save to CSV
statement ok
use "test/data/firms.csv", clear

statement ok
keep if year == 2018

statement ok
save "test/data/firms_2018.csv", replace

# reload saved file
statement ok
use "test/data/firms_2018.csv", clear

query I
count
----
3

# append
statement ok
use "test/data/firms.csv", clear

statement ok
keep if year == 2017

statement ok
append using "test/data/firms_2018.csv"

query I
count
----
5

# mvencode
statement ok
use "test/data/firms.csv", clear

statement ok
replace revenue = NULL if year == 2017

statement ok
mvencode revenue, mv(0)

query I
list revenue
----
0
2000
0
3000
500

statement ok
clear

