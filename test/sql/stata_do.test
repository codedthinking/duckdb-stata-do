# ============================================================
# M9.5: label variable, label define, label values
# ============================================================

# label variable
statement ok
use "test/data/firms.csv", clear

statement ok
label variable revenue "Annual revenue in USD"

statement ok
label variable year "Fiscal year"

# label define and label values
statement ok
label define sector_lbl 1 "Primary" 2 "Secondary" 3 "Tertiary"

statement ok
label values id sector_lbl

# codebook — alias for describe that doesn't conflict with SQL
# Note: empty label fields are empty strings; sqllogictest puts each value on its own line
query IIII rowsort
codebook
----
id
BIGINT
(empty)
sector_lbl
name
VARCHAR
(empty)
(empty)
revenue
BIGINT
Annual revenue in USD
(empty)
year
BIGINT
Fiscal year
(empty)

# labels survive transformations
statement ok
keep if year == 2018

query IIII rowsort
codebook
----
id
BIGINT
(empty)
sector_lbl
name
VARCHAR
(empty)
(empty)
revenue
BIGINT
Annual revenue in USD
(empty)
year
BIGINT
Fiscal year
(empty)

# label list — show all defined labels
statement ok
use "test/data/firms.csv", clear

statement ok
label variable revenue "Annual revenue in USD"

statement ok
label define yesno 0 "No" 1 "Yes"

statement ok
label values id yesno

