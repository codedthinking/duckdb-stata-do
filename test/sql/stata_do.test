# name: test/sql/stata_do.test
# description: test stata_do extension
# group: [sql]

require stata_do

# ============================================================
# M0: Extension loads, standard SQL still works
# ============================================================

query I
SELECT 1
----
1

# ============================================================
# M1: use, list, clear, count
# ============================================================

statement ok
use "test/data/firms.csv", clear

query IIRI
list
----
1	Acme	1000	2017
2	Beta	2000	2018
3	Gamma	1500	2017
4	Delta	3000	2018
5	Epsilon	500	2018

query I
count
----
5

statement ok
clear

# ============================================================
# M2: keep, drop, rename
# ============================================================

statement ok
use "test/data/firms.csv", clear

# keep columns
statement ok
keep id name revenue year

query I
count
----
5

# Now reload and test keep if
statement ok
use "test/data/firms.csv", clear

statement ok
keep if year == 2018

query I
count
----
3

# Reload and test drop columns
statement ok
use "test/data/firms.csv", clear

statement ok
drop name

query IRI
list
----
1	1000	2017
2	2000	2018
3	1500	2017
4	3000	2018
5	500	2018

# Reload and test drop if
statement ok
use "test/data/firms.csv", clear

statement ok
drop if year == 2017

query I
count
----
3

# Test rename
statement ok
use "test/data/firms.csv", clear

statement ok
rename revenue sales

query IIIR
list
----
1	Acme	2017	1000
2	Beta	2018	2000
3	Gamma	2017	1500
4	Delta	2018	3000
5	Epsilon	2018	500

# ============================================================
# M3: generate, replace
# ============================================================

statement ok
use "test/data/firms.csv", clear

# generate new column
statement ok
generate ln_rev = log(revenue)

query IIRIR
list
----
1	Acme	1000	2017	6.907755278982137
2	Beta	2000	2018	7.600902459542082
3	Gamma	1500	2017	7.3132308093279215
4	Delta	3000	2018	8.006367567650246
5	Epsilon	500	2018	6.214608098422191

# generate with if condition
statement ok
use "test/data/firms.csv", clear

statement ok
generate big = revenue > 1000 if year == 2018

# replace
statement ok
use "test/data/firms.csv", clear

statement ok
replace revenue = revenue * 2

query I
list revenue
----
2000
4000
3000
6000
1000

# replace with if
statement ok
use "test/data/firms.csv", clear

statement ok
replace revenue = 0 if year == 2017

query I
list revenue
----
0
2000
0
3000
500

# ============================================================
# Chained operations
# ============================================================

statement ok
use "test/data/firms.csv", clear

statement ok
keep if year == 2018

statement ok
generate ln_rev = log(revenue)

statement ok
sort revenue

query IIRIR
list
----
5	Epsilon	500	2018	6.214608098422191
2	Beta	2000	2018	7.600902459542082
4	Delta	3000	2018	8.006367567650246

# ============================================================
# M4: sort, order, count, describe, head, tail, summarize
# ============================================================

# sort already tested above in chained operations

# order: reorder columns
statement ok
use "test/data/firms.csv", clear

statement ok
order year name

query IIRI
list
----
2017	Acme	1	1000
2018	Beta	2	2000
2017	Gamma	3	1500
2018	Delta	4	3000
2018	Epsilon	5	500

# describe
statement ok
use "test/data/firms.csv", clear

query II
describe
----
id	BIGINT
name	VARCHAR
revenue	BIGINT
year	BIGINT

# head
statement ok
use "test/data/firms.csv", clear

query IIRI
head 2
----
1	Acme	1000	2017
2	Beta	2000	2018

# tail
statement ok
use "test/data/firms.csv", clear

query IIRI
tail 2
----
4	Delta	3000	2018
5	Epsilon	500	2018

# summarize
statement ok
use "test/data/firms.csv", clear

query IRRIRRRI
summarize revenue
----
5	1600.0	961.7692030835673	500	1000.0	1500.0	2000.0	3000

# summarize with if
statement ok
summarize revenue if year == 2018

query IRRIRRRI
summarize revenue if year == 2018
----
3	1833.3333333333333	1258.3057763498999	500	1250.0	2000.0	2500.0	3000

# tabulate
statement ok
use "test/data/firms.csv", clear

query II
tabulate year
----
2017	2
2018	3

# ============================================================
# M5: egen, collapse, _n, _N
# ============================================================

# egen with by()
statement ok
use "test/data/firms.csv", clear

statement ok
egen mean_rev = mean(revenue), by(year)

statement ok
sort year id

query IIRIR
list
----
1	Acme	1000	2017	1250.0
3	Gamma	1500	2017	1250.0
2	Beta	2000	2018	1833.3333333333333
4	Delta	3000	2018	1833.3333333333333
5	Epsilon	500	2018	1833.3333333333333

# egen without by() — global aggregate as window
statement ok
use "test/data/firms.csv", clear

statement ok
egen max_rev = max(revenue)

query I
list max_rev
----
3000
3000
3000
3000
3000

# egen with count
statement ok
use "test/data/firms.csv", clear

statement ok
egen n_firms = count(id), by(year)

statement ok
sort year id

query I
list n_firms
----
2
2
3
3
3

# collapse with (func) syntax
statement ok
use "test/data/firms.csv", clear

statement ok
collapse (mean) avg_rev = revenue (sum) total_rev = revenue, by(year)

statement ok
sort year

query IRR
list
----
2017	1250.0	2500
2018	1833.3333333333333	5500

# collapse without by() — single row
statement ok
use "test/data/firms.csv", clear

statement ok
collapse (mean) avg = revenue (count) n = id

query RI
list
----
1600.0	5

# collapse shorthand: bare variable names without = assignment
statement ok
use "test/data/firms.csv", clear

statement ok
collapse (mean) revenue, by(year)

statement ok
sort year

query IR
list
----
2017	1250.0
2018	1833.3333333333333

# collapse then collapse again (chained)
statement ok
collapse (mean) revenue

query R
list
----
1541.6666666666665

# collapse with func(x) syntax
statement ok
use "test/data/firms.csv", clear

statement ok
collapse avg = mean(revenue), by(year)

statement ok
sort year

query IR
list
----
2017	1250.0
2018	1833.3333333333333

# _n and _N special variables
statement ok
use "test/data/firms.csv", clear

statement ok
generate row = _n

statement ok
generate total = _N

query II
list row total
----
1	5
2	5
3	5
4	5
5	5

# _n with keep if (last row)
statement ok
use "test/data/firms.csv", clear

statement ok
keep if _n == _N

query I
count
----
1

statement ok
clear

# ============================================================
# M5.5: do "script.do"
# ============================================================

# Run a .do file (no semicolons, with comments)
statement ok
do "test/data/clean.do"

# Verify state: 2018 firms sorted by revenue with ln_rev
query IIRIR
list
----
5	Epsilon	500	2018	6.214608098422191
2	Beta	2000	2018	7.600902459542082
4	Delta	3000	2018	8.006367567650246

query I
count
----
3

statement ok
clear
