# name: test/sql/write_dta.test
# description: test write_dta (COPY TO FORMAT dta) and round-trip
# group: [sql]

require dodo

# ============================================================
# Basic round-trip: COPY TO then read_dta
# ============================================================

statement ok
COPY (SELECT 1::INTEGER AS id, 'hello' AS name, 42.5 AS value) TO '__TEST_DIR__/basic.dta' (FORMAT dta)

query IIR
SELECT * FROM read_dta('__TEST_DIR__/basic.dta')
----
1	hello	42.5

# ============================================================
# Type mapping: INTEGER -> long (int32)
# ============================================================

statement ok
COPY (SELECT 1::INTEGER AS x, -100::INTEGER AS y, 2147483620::INTEGER AS z) TO '__TEST_DIR__/int.dta' (FORMAT dta)

query III
SELECT typeof(x), typeof(y), typeof(z) FROM read_dta('__TEST_DIR__/int.dta')
----
INTEGER	INTEGER	INTEGER

query III
SELECT * FROM read_dta('__TEST_DIR__/int.dta')
----
1	-100	2147483620

# ============================================================
# Type mapping: TINYINT -> byte
# ============================================================

statement ok
COPY (SELECT 1::TINYINT AS a, 100::TINYINT AS b) TO '__TEST_DIR__/tinyint.dta' (FORMAT dta)

query II
SELECT typeof(a), typeof(b) FROM read_dta('__TEST_DIR__/tinyint.dta')
----
TINYINT	TINYINT

query II
SELECT * FROM read_dta('__TEST_DIR__/tinyint.dta')
----
1	100

# ============================================================
# Type mapping: SMALLINT -> int (int16)
# ============================================================

statement ok
COPY (SELECT 1::SMALLINT AS a, 32000::SMALLINT AS b) TO '__TEST_DIR__/smallint.dta' (FORMAT dta)

query II
SELECT typeof(a), typeof(b) FROM read_dta('__TEST_DIR__/smallint.dta')
----
SMALLINT	SMALLINT

query II
SELECT * FROM read_dta('__TEST_DIR__/smallint.dta')
----
1	32000

# ============================================================
# Type mapping: BIGINT -> double
# ============================================================

statement ok
COPY (SELECT 1000000000000::BIGINT AS big) TO '__TEST_DIR__/bigint.dta' (FORMAT dta)

query I
SELECT typeof(big) FROM read_dta('__TEST_DIR__/bigint.dta')
----
DOUBLE

query R
SELECT * FROM read_dta('__TEST_DIR__/bigint.dta')
----
1000000000000.0

# ============================================================
# Type mapping: FLOAT -> float
# ============================================================

statement ok
COPY (SELECT 3.14::FLOAT AS pi) TO '__TEST_DIR__/float.dta' (FORMAT dta)

query I
SELECT typeof(pi) FROM read_dta('__TEST_DIR__/float.dta')
----
FLOAT

# ============================================================
# Type mapping: DOUBLE -> double
# ============================================================

statement ok
COPY (SELECT 2.718281828::DOUBLE AS e) TO '__TEST_DIR__/double.dta' (FORMAT dta)

query R
SELECT * FROM read_dta('__TEST_DIR__/double.dta')
----
2.718281828

# ============================================================
# Type mapping: BOOLEAN -> byte
# ============================================================

statement ok
COPY (SELECT true AS a, false AS b) TO '__TEST_DIR__/bool.dta' (FORMAT dta)

query II
SELECT * FROM read_dta('__TEST_DIR__/bool.dta')
----
1	0

# ============================================================
# Type mapping: DATE -> double with %td format
# ============================================================

statement ok
COPY (SELECT DATE '2024-01-15' AS dt) TO '__TEST_DIR__/date.dta' (FORMAT dta)

query I
SELECT typeof(dt) FROM read_dta('__TEST_DIR__/date.dta')
----
DATE

query T
SELECT * FROM read_dta('__TEST_DIR__/date.dta')
----
2024-01-15

# ============================================================
# Type mapping: TIMESTAMP -> double with %tc format
# ============================================================

statement ok
COPY (SELECT TIMESTAMP '2024-01-15 10:30:00' AS ts) TO '__TEST_DIR__/timestamp.dta' (FORMAT dta)

query I
SELECT typeof(ts) FROM read_dta('__TEST_DIR__/timestamp.dta')
----
TIMESTAMP

query T
SELECT * FROM read_dta('__TEST_DIR__/timestamp.dta')
----
2024-01-15 10:30:00

# ============================================================
# Type mapping: VARCHAR -> strL
# ============================================================

statement ok
COPY (SELECT 'short' AS a, 'a longer string value here' AS b) TO '__TEST_DIR__/varchar.dta' (FORMAT dta)

query II
SELECT * FROM read_dta('__TEST_DIR__/varchar.dta')
----
short	a longer string value here

# ============================================================
# NULL handling for all types
# ============================================================

statement ok
COPY (SELECT NULL::INTEGER AS a, NULL::DOUBLE AS b, NULL::VARCHAR AS c, NULL::DATE AS d, NULL::TINYINT AS e) TO '__TEST_DIR__/nulls.dta' (FORMAT dta)

query IIIII
SELECT a IS NULL, b IS NULL, c IS NULL, d IS NULL, e IS NULL FROM read_dta('__TEST_DIR__/nulls.dta')
----
true	true	true	true	true

# ============================================================
# Multiple rows
# ============================================================

statement ok
COPY (SELECT * FROM (VALUES (1, 'a', 10.0), (2, 'b', 20.0), (3, 'c', 30.0)) AS t(id, name, value)) TO '__TEST_DIR__/multi.dta' (FORMAT dta)

query I
SELECT count(*) FROM read_dta('__TEST_DIR__/multi.dta')
----
3

query IIR
SELECT * FROM read_dta('__TEST_DIR__/multi.dta') ORDER BY id
----
1	a	10.0
2	b	20.0
3	c	30.0

# ============================================================
# Round-trip: read existing .dta, write, read back
# ============================================================

statement ok
COPY (SELECT * FROM read_dta('test/data/auto.dta')) TO '__TEST_DIR__/roundtrip.dta' (FORMAT dta)

query IIRI
SELECT * FROM read_dta('__TEST_DIR__/roundtrip.dta') ORDER BY id
----
1	Acme	1000.0	2017
2	Beta Corp	2500.5	2018
3	Gamma	NULL	2018

# ============================================================
# Boundary values: TINYINT (byte) range -127..100
# ============================================================

statement ok
COPY (SELECT (-127)::TINYINT AS mn, 100::TINYINT AS mx) TO '__TEST_DIR__/byte_bounds.dta' (FORMAT dta)

query II
SELECT * FROM read_dta('__TEST_DIR__/byte_bounds.dta')
----
-127	100

# Values above 100 are missing sentinels in Stata
statement ok
COPY (SELECT 101::TINYINT AS v) TO '__TEST_DIR__/byte_missing.dta' (FORMAT dta)

query I
SELECT v IS NULL FROM read_dta('__TEST_DIR__/byte_missing.dta')
----
true

# ============================================================
# Boundary values: SMALLINT (int) range -32767..32740
# ============================================================

statement ok
COPY (SELECT (-32767)::SMALLINT AS mn, 32740::SMALLINT AS mx) TO '__TEST_DIR__/int_bounds.dta' (FORMAT dta)

query II
SELECT * FROM read_dta('__TEST_DIR__/int_bounds.dta')
----
-32767	32740

# ============================================================
# Boundary values: INTEGER (long) range -2147483647..2147483620
# ============================================================

statement ok
COPY (SELECT (-2147483647)::INTEGER AS mn, 2147483620::INTEGER AS mx) TO '__TEST_DIR__/long_bounds.dta' (FORMAT dta)

query II
SELECT * FROM read_dta('__TEST_DIR__/long_bounds.dta')
----
-2147483647	2147483620

# ============================================================
# Unsigned integers: cast to larger signed type
# ============================================================

# UTINYINT -> byte (fits since max utinyint=255 > 100 means some become missing)
statement ok
COPY (SELECT 50::UTINYINT AS a) TO '__TEST_DIR__/utinyint.dta' (FORMAT dta)

query I
SELECT * FROM read_dta('__TEST_DIR__/utinyint.dta')
----
50

# USMALLINT -> int
statement ok
COPY (SELECT 30000::USMALLINT AS a) TO '__TEST_DIR__/usmallint.dta' (FORMAT dta)

query I
SELECT * FROM read_dta('__TEST_DIR__/usmallint.dta')
----
30000

# UINTEGER -> long
statement ok
COPY (SELECT 1000000::UINTEGER AS a) TO '__TEST_DIR__/uint.dta' (FORMAT dta)

query I
SELECT * FROM read_dta('__TEST_DIR__/uint.dta')
----
1000000

# ============================================================
# Boolean: true=1, false=0
# ============================================================

statement ok
COPY (SELECT true AS t, false AS f, NULL::BOOLEAN AS n) TO '__TEST_DIR__/bool2.dta' (FORMAT dta)

query III
SELECT * FROM read_dta('__TEST_DIR__/bool2.dta')
----
1	0	NULL

# ============================================================
# FLOAT precision round-trip
# ============================================================

statement ok
COPY (SELECT 1.5::FLOAT AS a, (-0.001)::FLOAT AS b, 0.0::FLOAT AS c) TO '__TEST_DIR__/float_prec.dta' (FORMAT dta)

query RRR
SELECT * FROM read_dta('__TEST_DIR__/float_prec.dta')
----
1.5	-0.001	0.0

# ============================================================
# DOUBLE precision round-trip
# ============================================================

statement ok
COPY (SELECT 1.23456789012345::DOUBLE AS a, (-999.999)::DOUBLE AS b) TO '__TEST_DIR__/double_prec.dta' (FORMAT dta)

query RR
SELECT * FROM read_dta('__TEST_DIR__/double_prec.dta')
----
1.23456789012345	-999.999

# ============================================================
# DATE boundary: epoch (1970-01-01), Stata epoch (1960-01-01)
# ============================================================

statement ok
COPY (SELECT DATE '1960-01-01' AS stata_epoch, DATE '1970-01-01' AS unix_epoch, DATE '2000-06-15' AS y2k) TO '__TEST_DIR__/date_bounds.dta' (FORMAT dta)

query TTT
SELECT * FROM read_dta('__TEST_DIR__/date_bounds.dta')
----
1960-01-01	1970-01-01	2000-06-15

# ============================================================
# Mixed NULLs and values in multiple rows
# ============================================================

statement ok
COPY (SELECT * FROM (VALUES
  (1, 'a', 10.0, true),
  (NULL, 'b', NULL, false),
  (3, NULL, 30.0, NULL)
) AS t(id, name, val, flag)) TO '__TEST_DIR__/mixed_nulls.dta' (FORMAT dta)

query IIRI
SELECT * FROM read_dta('__TEST_DIR__/mixed_nulls.dta') ORDER BY COALESCE(id, 999)
----
1	a	10.0	1
3	NULL	30.0	NULL
NULL	b	NULL	0

# ============================================================
# Empty string vs NULL string
# ============================================================

statement ok
COPY (SELECT '' AS empty, NULL::VARCHAR AS missing) TO '__TEST_DIR__/empty_str.dta' (FORMAT dta)

query II
SELECT empty IS NULL, missing IS NULL FROM read_dta('__TEST_DIR__/empty_str.dta')
----
true	true

# ============================================================
# save command with .dta extension
# ============================================================

statement ok
use "test/data/auto.dta", clear

statement ok
keep if year == 2018

statement ok
save "__TEST_DIR__/save_test.dta"

statement ok
clear

query I
SELECT count(*) FROM read_dta('__TEST_DIR__/save_test.dta')
----
2

query IIR
SELECT id, name, revenue FROM read_dta('__TEST_DIR__/save_test.dta') ORDER BY id
----
2	Beta Corp	2500.5
3	Gamma	NULL
